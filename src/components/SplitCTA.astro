---
import '../styles/components/split-cta.css';
---

<section class="split-cta" id="join-us">
  <!-- Careers Left Column -->
  <div class="split-cta__half split-cta__half--careers" data-animate="fade-right">
    <div class="split-cta__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="8.5" cy="7" r="4"/>
        <line x1="20" y1="8" x2="20" y2="14"/>
        <line x1="23" y1="11" x2="17" y2="11"/>
      </svg>
    </div>
    <h2 class="split-cta__title">Ready to join our dynamic team?</h2>
    <a href="/careers" class="split-cta__btn split-cta__btn--purple" aria-label="View Open Positions in Careers">
      View Open Positions
    </a>
  </div>

  <!-- Contact Right Column -->
  <div class="split-cta__half split-cta__half--contact" data-animate="fade-left">
    <div class="split-cta__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
      </svg>
    </div>
    <h2 class="split-cta__title">Have a project in mind?</h2>
    <a href="/contact" class="split-cta__btn split-cta__btn--cyan" aria-label="Contact Us Today">
      Contact Us Today
    </a>
  </div>
</section>
