---
import '../styles/components/unlimited-possibilities.css';
---

<section class="possibilities" id="possibilities">
  <div class="container possibilities__container">
    <div class="possibilities__content">
      <h2 class="possibilities__title" data-animate="fade-up">Unlimited Possibilities / Powerful Solution</h2>
      <p class="possibilities__subtitle" data-animate="fade-up" data-delay="0.2">
        To work with our clients to identify real business opportunities and match up the right technologies in order to create fast and effective applications.
      </p>
      
      <ul class="possibilities__list" data-animate="fade-up" data-delay="0.4">
        <li class="possibilities__item">
          <span class="possibilities__item-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </span>
          Web Development
        </li>
        <li class="possibilities__item">
          <span class="possibilities__item-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </span>
          Mobile App Development
        </li>
        <li class="possibilities__item">
          <span class="possibilities__item-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </span>
          Startups
        </li>
        <li class="possibilities__item">
          <span class="possibilities__item-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </span>
          Quality Assurance
        </li>
        <li class="possibilities__item">
          <span class="possibilities__item-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </span>
          Dedicated Teams
        </li>
      </ul>
    </div>
    
    <div class="possibilities__graphic" data-animate="fade-in" data-delay="0.6">
      <svg class="possibilities__svg" viewBox="0 0 500 400" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <!-- Background Grid -->
        <rect width="500" height="400" rx="24" fill="var(--bg-card)" stroke="var(--border-light)" stroke-width="2"/>
        <g stroke="rgba(0,0,0,0.03)" stroke-width="1">
          <line x1="50" y1="0" x2="50" y2="400"/>
          <line x1="100" y1="0" x2="100" y2="400"/>
          <line x1="150" y1="0" x2="150" y2="400"/>
          <line x1="200" y1="0" x2="200" y2="400"/>
          <line x1="250" y1="0" x2="250" y2="400"/>
          <line x1="300" y1="0" x2="300" y2="400"/>
          <line x1="350" y1="0" x2="350" y2="400"/>
          <line x1="400" y1="0" x2="400" y2="400"/>
          <line x1="450" y1="0" x2="450" y2="400"/>
          <line x1="0" y1="50" x2="500" y2="50"/>
          <line x1="0" y1="100" x2="500" y2="100"/>
          <line x1="0" y1="150" x2="500" y2="150"/>
          <line x1="0" y1="200" x2="500" y2="200"/>
          <line x1="0" y1="250" x2="500" y2="250"/>
          <line x1="0" y1="300" x2="500" y2="300"/>
          <line x1="0" y1="350" x2="500" y2="350"/>
        </g>
        
        <!-- Abstract Dashboard Elements -->
        <rect x="40" y="40" width="420" height="60" rx="12" fill="var(--bg-secondary)" stroke="var(--border-light)"/>
        <circle cx="75" cy="70" r="15" fill="var(--accent-blue)"/>
        <rect x="110" y="60" width="120" height="8" rx="4" fill="var(--text-muted)" opacity="0.5"/>
        <rect x="110" y="72" width="80" height="6" rx="3" fill="var(--text-muted)" opacity="0.3"/>
        
        <!-- Progress Bars / Stat Bars -->
        <g transform="translate(40, 130)">
          <!-- Item 1 -->
          <rect x="0" y="0" width="200" height="110" rx="16" fill="var(--bg-secondary)"/>
          <circle cx="40" cy="40" r="16" fill="var(--accent-blue-light)" stroke="var(--accent-blue)" stroke-width="2"/>
          <path d="M35 40l3 3 7-7" stroke="var(--accent-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <rect x="70" y="30" width="90" height="8" rx="4" fill="var(--text-primary)"/>
          <rect x="70" y="44" width="70" height="6" rx="3" fill="var(--text-muted)"/>
          <rect x="24" y="80" width="152" height="8" rx="4" fill="rgba(11, 136, 238, 0.2)"/>
          <rect x="24" y="80" width="120" height="8" rx="4" fill="var(--accent-blue)"/>
        </g>
        
        <g transform="translate(260, 130)">
          <!-- Item 2 -->
          <rect x="0" y="0" width="200" height="110" rx="16" fill="var(--bg-secondary)"/>
          <circle cx="40" cy="40" r="16" fill="rgba(168, 85, 247, 0.1)" stroke="var(--neon-purple)" stroke-width="2"/>
          <path d="M35 40l3 3 7-7" stroke="var(--neon-purple)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <rect x="70" y="30" width="90" height="8" rx="4" fill="var(--text-primary)"/>
          <rect x="70" y="44" width="70" height="6" rx="3" fill="var(--text-muted)"/>
          <rect x="24" y="80" width="152" height="8" rx="4" fill="rgba(168, 85, 247, 0.2)"/>
          <rect x="24" y="80" width="90" height="8" rx="4" fill="var(--neon-purple)"/>
        </g>

        <!-- Bottom Graphic Area -->
        <rect x="40" y="270" width="420" height="90" rx="16" fill="var(--bg-secondary)"/>
        <path d="M60 330c20-20 40-10 60-30s40-40 60-40 40 50 60 30 40-60 60-60 40 40 60 20l20-10" stroke="url(#possibilities-chart-gradient)" stroke-width="4" stroke-linecap="round"/>
        
        <!-- Definitions -->
        <defs>
          <linearGradient id="possibilities-chart-gradient" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="var(--accent-blue)"/>
            <stop offset="50%" stop-color="var(--neon-purple)"/>
            <stop offset="100%" stop-color="var(--neon-cyan)"/>
          </linearGradient>
        </defs>
      </svg>
    </div>
  </div>
</section>
