<form class="contact-form" id="contact-form" aria-label="Contact Form" data-animate="fade-up">
  <div class="contact-form__group">
    <label for="name" class="contact-form__label">Name <span aria-hidden="true">*</span></label>
    <input type="text" id="name" name="name" class="contact-form__input" required aria-required="true" placeholder="John Doe">
  </div>
  
  <div class="contact-form__row">
    <div class="contact-form__group">
      <label for="email" class="contact-form__label">Email <span aria-hidden="true">*</span></label>
      <input type="email" id="email" name="email" class="contact-form__input" required aria-required="true" placeholder="john@example.com">
    </div>
    
    <div class="contact-form__group">
      <label for="phone" class="contact-form__label">Phone Number</label>
      <input type="tel" id="phone" name="phone" class="contact-form__input" placeholder="+1 234 567 890">
    </div>
  </div>
  
  <div class="contact-form__group">
    <label for="subject" class="contact-form__label">Subject <span aria-hidden="true">*</span></label>
    <input type="text" id="subject" name="subject" class="contact-form__input" required aria-required="true" placeholder="How can we help you?">
  </div>
  
  <div class="contact-form__group">
    <label for="message" class="contact-form__label">Message <span aria-hidden="true">*</span></label>
    <textarea id="message" name="message" class="contact-form__textarea" rows="5" required aria-required="true" placeholder="Write your message here..."></textarea>
  </div>
  
  <button type="submit" class="contact-form__submit btn btn--primary">Send Message</button>
  
  <div class="contact-form__feedback" id="form-feedback" aria-live="polite"></div>
</form>

<style>
  .contact-form {
    background: var(--bg-primary, #ffffff);
    padding: var(--space-8, 32px);
    border-radius: var(--radius-lg, 16px);
    box-shadow: var(--shadow-card, 0 4px 6px rgba(0,0,0,0.05));
  }

  .contact-form__group {
    margin-bottom: var(--space-5, 20px);
  }

  .contact-form__row {
    display: flex;
    flex-direction: column;
    gap: var(--space-5, 20px);
    margin-bottom: var(--space-5, 20px);
  }

  @media (min-width: 768px) {
    .contact-form__row {
      flex-direction: row;
      gap: var(--space-6, 24px);
    }
    
    .contact-form__row .contact-form__group {
      flex: 1;
      margin-bottom: 0;
    }
  }

  .contact-form__label {
    display: block;
    font-size: var(--text-sm, 0.875rem);
    font-weight: 600;
    color: var(--text-secondary, #475569);
    margin-bottom: var(--space-2, 8px);
  }

  .contact-form__input,
  .contact-form__textarea {
    width: 100%;
    padding: var(--space-3, 12px) var(--space-4, 16px);
    border: 1px solid var(--border-color, #e2e8f0);
    border-radius: var(--radius-md, 8px);
    background: var(--bg-primary, #ffffff);
    color: var(--text-primary, #0f172a);
    font-family: inherit;
    font-size: var(--text-base, 1rem);
    transition: border-color var(--duration-fast, 0.2s) ease, box-shadow var(--duration-fast, 0.2s) ease;
  }

  .contact-form__input:focus,
  .contact-form__textarea:focus {
    outline: none;
    border-color: var(--accent-blue, #3b82f6);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }

  .contact-form__textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-form__submit {
    width: 100%;
    margin-top: var(--space-4, 16px);
    background: var(--accent-gold, #FFC107);
    color: var(--text-primary, #0f172a);
    font-weight: 700;
    padding: var(--space-4, 16px);
    border-radius: var(--radius-md, 8px);
    border: none;
    cursor: pointer;
    font-size: var(--text-base, 1rem);
    transition: background-color var(--duration-fast, 0.2s) ease;
  }

  .contact-form__submit:hover {
    background: #e5ac00; /* slightly darker gold */
  }

  .contact-form__feedback {
    margin-top: var(--space-4, 16px);
    text-align: center;
    font-weight: 500;
  }
  
  .contact-form__feedback.success {
    color: #10b981; /* emerald-500 */
  }
</style>

<script>
  function initContactForm() {
    const form = document.getElementById('contact-form');
    const feedback = document.getElementById('form-feedback');
    
    if (form && feedback) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        
        // UI-only form submission per requirements
        const submitBtn = form.querySelector('.contact-form__submit');
        const originalText = submitBtn.textContent;
        
        submitBtn.textContent = 'Sending...';
        submitBtn.disabled = true;
        
        setTimeout(() => {
          form.reset();
          submitBtn.textContent = originalText;
          submitBtn.disabled = false;
          
          feedback.textContent = 'Thank you for your message! We will get back to you soon.';
          feedback.classList.add('success');
          
          setTimeout(() => {
            feedback.textContent = '';
            feedback.classList.remove('success');
          }, 5000);
        }, 1000);
      });
    }
  }

  document.addEventListener('astro:page-load', initContactForm);
  initContactForm();
</script>
