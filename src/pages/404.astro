---
import Layout from '../layouts/Layout.astro';
---

<Layout pageTitle="Page Not Found" pageDescription="The page you are looking for does not exist.">
  <div class="not-found">
    <div class="container not-found__container">
      <h1 class="not-found__title" data-animate="fade-up">404</h1>
      <h2 class="not-found__subtitle" data-animate="fade-up" style="--stagger: 0.1">Page Not Found</h2>
      <p class="not-found__text" data-animate="fade-up" style="--stagger: 0.2">Oops! The page you are looking for doesn't exist or has been moved.</p>
      <div data-animate="fade-up" style="--stagger: 0.3">
        <a href="/" class="btn btn--primary not-found__btn">Back to Home</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .not-found {
    min-height: calc(100vh - 300px);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-20, 80px) 0;
    background: var(--bg-tertiary, #f8fafc);
  }

  .not-found__title {
    font-size: clamp(6rem, 15vw, 12rem);
    font-weight: 800;
    line-height: 1;
    color: var(--accent-gold, #FFC107);
    margin-bottom: var(--space-4, 16px);
    text-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }

  .not-found__subtitle {
    font-size: var(--text-3xl, 1.875rem);
    font-weight: 700;
    color: var(--text-primary, #0f172a);
    margin-bottom: var(--space-4, 16px);
  }

  .not-found__text {
    font-size: var(--text-lg, 1.125rem);
    color: var(--text-secondary, #475569);
    margin-bottom: var(--space-8, 32px);
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .not-found__btn {
    display: inline-block;
  }
</style>
