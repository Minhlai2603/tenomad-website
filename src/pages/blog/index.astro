---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

// Extract categories
const allCategories = [...new Set(allPosts.map((post) => post.data.category))].filter(Boolean);
---

<Layout pageTitle="Blog" pageDescription="Insights, news, and guides from Tenomad.">
  <div class="blog-page">
    <!-- Banner -->
    <section class="blog-banner" data-animate="fade-up">
      <div class="container blog-banner__container">
        <h1 class="blog-banner__title">Our Blog</h1>
        <p class="blog-banner__subtitle">Thoughts, news, and insights from our team.</p>
      </div>
    </section>

    <!-- Main Content -->
    <section class="blog-content section">
      <div class="container blog-container">
        
        <!-- Post Grid -->
        <main class="blog-main" data-animate="fade-up" style="--stagger: 0.1">
          <div class="post-grid">
            {sortedPosts.map((post) => (
              <article class="post-card">
                <a href={`/blog/${post.slug}`} class="post-card__link">
                  <div class="post-card__image-wrapper">
                    <img src={`/assets/${post.data.thumbnail}`} alt={post.data.title} loading="lazy" class="post-card__image" />
                    <span class="post-card__category">{post.data.category}</span>
                  </div>
                  <div class="post-card__content">
                    <div class="post-card__meta">
                      <time datetime={post.data.date}>{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                    </div>
                    <h2 class="post-card__title">{post.data.title}</h2>
                    <p class="post-card__excerpt">{post.data.excerpt}</p>
                    <span class="post-card__readmore">Read More →</span>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </main>

        <!-- Sidebar -->
        <aside class="blog-sidebar" data-animate="fade-up" style="--stagger: 0.2">
          <!-- Search Widget -->
          <div class="sidebar-widget">
            <h3 class="sidebar-widget__title">Search</h3>
            <form class="search-form" action="#" onsubmit="event.preventDefault();">
              <input type="search" placeholder="Search posts..." class="search-form__input" aria-label="Search posts">
              <button type="submit" class="search-form__btn" aria-label="Submit search">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="8"></circle>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
              </button>
            </form>
          </div>

          <!-- Categories Widget -->
          <div class="sidebar-widget">
            <h3 class="sidebar-widget__title">Categories</h3>
            <ul class="categories-list">
              {allCategories.map((category) => (
                <li class="categories-list__item">
                  <a href="#" class="categories-list__link">{category}</a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Recent Posts Widget -->
          <div class="sidebar-widget">
            <h3 class="sidebar-widget__title">Recent Posts</h3>
            <ul class="recent-posts">
              {sortedPosts.slice(0, 3).map((post) => (
                <li class="recent-posts__item">
                  <a href={`/blog/${post.slug}`} class="recent-posts__link">
                    <img src={`/assets/${post.data.thumbnail}`} alt="" class="recent-posts__img" loading="lazy" />
                    <div class="recent-posts__info">
                      <h4 class="recent-posts__title">{post.data.title}</h4>
                      <time class="recent-posts__date">{new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</time>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>

      </div>
    </section>
  </div>
</Layout>

<style>
  .blog-banner {
    background: var(--bg-tertiary, #f8fafc);
    padding: var(--space-20, 80px) 0 var(--space-10, 40px);
    text-align: center;
  }

  .blog-banner__title {
    font-size: var(--text-hero, 3.5rem);
    color: var(--text-primary, #0f172a);
    margin-bottom: var(--space-4, 16px);
  }

  .blog-banner__subtitle {
    font-size: var(--text-xl, 1.25rem);
    color: var(--text-secondary, #475569);
  }

  .blog-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10, 40px);
  }

  @media (min-width: 1024px) {
    .blog-container {
      grid-template-columns: 2fr 1fr;
      gap: var(--space-12, 48px);
      align-items: start;
    }
  }

  .post-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8, 32px);
  }

  @media (min-width: 768px) {
    .post-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .post-card {
    background: var(--bg-primary, #ffffff);
    border-radius: var(--radius-lg, 16px);
    overflow: hidden;
    box-shadow: var(--shadow-card, 0 4px 6px rgba(0,0,0,0.05));
    transition: transform var(--duration-normal, 0.3s) ease, box-shadow var(--duration-normal, 0.3s) ease;
    height: 100%;
  }

  .post-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-hover, 0 10px 20px rgba(0,0,0,0.1));
  }

  .post-card__link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .post-card__image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .post-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow, 0.5s) ease;
  }

  .post-card:hover .post-card__image {
    transform: scale(1.05);
  }

  .post-card__category {
    position: absolute;
    top: var(--space-4, 16px);
    left: var(--space-4, 16px);
    background: var(--accent-gold, #FFC107);
    color: var(--text-primary, #0f172a);
    font-size: var(--text-xs, 0.75rem);
    font-weight: 700;
    padding: var(--space-1, 4px) var(--space-3, 12px);
    border-radius: var(--radius-full, 9999px);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .post-card__content {
    padding: var(--space-6, 24px);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .post-card__meta {
    font-size: var(--text-sm, 0.875rem);
    color: var(--text-muted, #64748b);
    margin-bottom: var(--space-2, 8px);
  }

  .post-card__title {
    font-size: var(--text-xl, 1.25rem);
    font-weight: 700;
    color: var(--text-primary, #0f172a);
    margin-bottom: var(--space-3, 12px);
    line-height: 1.4;
  }

  .post-card__link:hover .post-card__title {
    color: var(--accent-blue, #3b82f6);
  }

  .post-card__excerpt {
    color: var(--text-secondary, #475569);
    margin-bottom: var(--space-4, 16px);
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card__readmore {
    font-size: var(--text-sm, 0.875rem);
    font-weight: 700;
    color: var(--accent-blue, #3b82f6);
    display: inline-flex;
    align-items: center;
    transition: transform var(--duration-fast, 0.2s) ease;
  }

  .post-card__link:hover .post-card__readmore {
    transform: translateX(5px);
  }

  /* Sidebar Styles */
  .blog-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-8, 32px);
  }

  .sidebar-widget {
    background: var(--bg-tertiary, #f8fafc);
    padding: var(--space-6, 24px);
    border-radius: var(--radius-md, 8px);
  }

  .sidebar-widget__title {
    font-size: var(--text-lg, 1.125rem);
    font-weight: 700;
    color: var(--text-primary, #0f172a);
    margin-bottom: var(--space-4, 16px);
    padding-bottom: var(--space-2, 8px);
    border-bottom: 2px solid var(--accent-gold, #FFC107);
    display: inline-block;
  }

  .search-form {
    display: flex;
    position: relative;
  }

  .search-form__input {
    width: 100%;
    padding: var(--space-3, 12px) var(--space-10, 40px) var(--space-3, 12px) var(--space-4, 16px);
    border: 1px solid var(--border-color, #e2e8f0);
    border-radius: var(--radius-md, 8px);
    font-family: inherit;
  }

  .search-form__btn {
    position: absolute;
    right: 0;
    top: 0;
    height: 100%;
    width: 44px;
    background: none;
    border: none;
    color: var(--text-muted, #64748b);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .search-form__btn:hover {
    color: var(--accent-blue, #3b82f6);
  }

  .categories-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .categories-list__item {
    margin-bottom: var(--space-2, 8px);
  }

  .categories-list__link {
    display: block;
    padding: var(--space-2, 8px) 0;
    color: var(--text-secondary, #475569);
    text-decoration: none;
    transition: color var(--duration-fast, 0.2s) ease;
    border-bottom: 1px solid var(--border-color, #e2e8f0);
  }

  .categories-list__link:hover {
    color: var(--accent-blue, #3b82f6);
    padding-left: var(--space-1, 4px);
  }

  .recent-posts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4, 16px);
  }

  .recent-posts__link {
    display: flex;
    gap: var(--space-3, 12px);
    text-decoration: none;
    color: inherit;
    align-items: center;
  }

  .recent-posts__img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: var(--radius-sm, 4px);
  }

  .recent-posts__info {
    flex: 1;
  }

  .recent-posts__title {
    font-size: var(--text-sm, 0.875rem);
    font-weight: 600;
    color: var(--text-primary, #0f172a);
    margin-bottom: var(--space-1, 4px);
    line-height: 1.4;
    transition: color var(--duration-fast, 0.2s) ease;
  }

  .recent-posts__link:hover .recent-posts__title {
    color: var(--accent-blue, #3b82f6);
  }

  .recent-posts__date {
    font-size: var(--text-xs, 0.75rem);
    color: var(--text-muted, #64748b);
  }
</style>
